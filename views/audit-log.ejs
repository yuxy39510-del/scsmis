<%- include('header', { title: '操作日志' }) %>

<div class="page-header">
    <h4><i class="bi bi-shield-check"></i> 操作日志审计</h4>
    <p>记录所有用户的关键操作，用于安全审计与追溯</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger" role="alert"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
<% } %>

<div class="table-container">
    <div class="table-toolbar">
        <span class="toolbar-info">共 <%= totalPages * 10 %> 条记录（仅显示最近）</span>
    </div>
    <div class="table-responsive">
        <table class="table" aria-label="操作日志列表">
            <thead>
                <tr>
                    <th style="width:60px">#</th>
                    <th>操作用户</th>
                    <th>角色</th>
                    <th>操作类型</th>
                    <th>操作目标</th>
                    <th>详情</th>
                    <th>操作时间</th>
                </tr>
            </thead>
            <tbody>
                <% if (logs.length === 0) { %>
                <tr><td colspan="7"><div class="empty-state"><i class="bi bi-shield-check"></i><p>暂无操作日志记录</p></div></td></tr>
                <% } %>
                <% logs.forEach(function(log, i) { %>
                <tr>
                    <td><%= (page-1)*10 + i + 1 %></td>
                    <td>
                        <span class="fw-semibold"><%= log.f_user_name %></span>
                        <small class="text-muted d-block"><%= log.f_user_id %></small>
                    </td>
                    <td>
                        <% var roleIcons = {admin: '👑', teacher: '👨‍🏫', student: '🎓'}; %>
                        <%= roleIcons[log.f_role_type] || '' %>
                        <span class="badge bg-soft-primary text-primary"><%= log.f_role_type %></span>
                    </td>
                    <td>
                        <%
                        var actionColors = {
                            '登录': 'info', '修改密码': 'warning',
                            '添加': 'success', '编辑': 'primary', '删除': 'danger',
                            '选课': 'primary', '退课': 'warning',
                            '开课': 'success', '停开': 'danger',
                            '录入成绩': 'info'
                        };
                        var color = actionColors[log.f_action] || 'secondary';
                        %>
                        <span class="badge bg-<%= color %>"><%= log.f_action %></span>
                    </td>
                    <td><small><%= log.f_target || '-' %></small></td>
                    <td><small class="text-muted"><%= log.f_detail || '-' %></small></td>
                    <td><small class="text-muted"><%= log.f_created_at ? new Date(log.f_created_at).toLocaleString('zh-CN') : '-' %></small></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <!-- 分页 -->
    <% if (totalPages > 1) { %>
    <nav aria-label="审计日志分页">
        <ul class="pagination">
            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>"><a class="page-link" href="?page=<%= page-1 %>">&laquo;</a></li>
            <% for (var p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="?page=<%= p %>"><%= p %></a></li>
            <% } %>
            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>"><a class="page-link" href="?page=<%= page+1 %>">&raquo;</a></li>
        </ul>
    </nav>
    <% } %>
</div>

<%- include('footer') %>
