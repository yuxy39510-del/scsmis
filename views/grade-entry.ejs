<%- include('header', { title: '录成绩' }) %>

<div class="page-header">
    <h4><i class="bi bi-pencil-square"></i> 录入成绩</h4>
    <p>选择授课课程后，为选课学生录入或修改成绩</p>
</div>

<% if (typeof msg !== 'undefined' && msg) { %>
<div class="alert alert-info" role="alert"><i class="bi bi-info-circle"></i> <%= msg %></div>
<% } %>

<!-- 选择课程 -->
<div class="card mb-4">
    <div class="card-header"><span class="badge bg-primary me-2">第1步</span>选择课程</div>
    <div class="card-body">
        <form method="POST" action="/grade-entry/lookup" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label required">课程</label>
                <select name="course_id" class="form-select" required>
                    <option value="">— 选择课程 —</option>
                    <% teachCourses.forEach(tc => { %>
                    <option value="<%= tc.f_course_id %>" <%= selectedCourse && selectedCourse.course_id == tc.f_course_id && selectedCourse.teach_id == tc.f_teach_id ? 'selected' : '' %>>
                        <%= tc.course_name || tc['课程名称'] %> — <%= tc.f_teach_id %>
                    </option>
                    <% }) %>
                </select>
            </div>
            <input type="hidden" name="teach_id" value="<%= teachCourses.length > 0 ? teachCourses[0].f_teach_id : '' %>">
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> 查询学生</button>
            </div>
        </form>
    </div>
</div>

<% if (selectedCourse) { %>
<!-- 学生成绩列表 -->
<div class="card">
    <div class="card-header"><span class="badge bg-success me-2">第2步</span>录入成绩 — 课程 <%= selectedCourse.course_id %></div>
    <div class="card-body">
        <% if (students.length === 0) { %>
        <div class="empty-state"><i class="bi bi-inbox"></i><p>暂无学生选此课程</p></div>
        <% } else { %>
        <div class="table-responsive">
            <table class="table" aria-label="学生成绩列表">
                <thead><tr><th>学号</th><th>姓名</th><th>当前成绩</th><th>操作</th></tr></thead>
                <tbody>
                <% students.forEach(s => { %>
                <tr>
                    <td><span class="badge bg-info"><%= s.f_stu_id %></span></td>
                    <td><strong><%= s.student_name %></strong></td>
                    <td>
                        <% if (s.f_score !== null) { %>
                        <span class="text-success fw-bold"><%= s.f_score %></span>
                        <% } else { %>
                        <span class="badge bg-soft-primary text-primary">未录入</span>
                        <% } %>
                    </td>
                    <td>
                        <form method="POST" action="/grade-entry/save" class="row g-2 align-items-center">
                            <input type="hidden" name="course_id" value="<%= selectedCourse.course_id %>">
                            <input type="hidden" name="teach_id" value="<%= selectedCourse.teach_id %>">
                            <input type="hidden" name="stu_id" value="<%= s.f_stu_id %>">
                            <div class="col-auto">
                                <input type="number" name="score" class="form-control form-control-sm" style="width:80px"
                                       placeholder="0-100" min="0" max="100" step="0.1"
                                       value="<%= s.f_score !== null ? s.f_score : '' %>">
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> 保存</button>
                            </div>
                        </form>
                    </td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</div>
<% } %>

<%- include('footer') %>
